DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_dashboard"

API_PORT=3000
SOCKET_IO_PORT=3001
CORS_ORIGIN_1=
CORS_ORIGIN_2=

NODE_ENV=development

JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=

INVOICE_GENERATOR_API_KEY=

REDIS_HOST=localhost
REDIS_PORT=6379

TG_API_ID=
TG_API_HASH=
TG_GROUP=
TG_PROPOSAL_USER_ID=00000000-0000-0000-0000-000000000010
TG_BACKFILL_LIMIT=
TG_BACKFILL_BATCH_SIZE=
TG_BACKFILL_BATCH_DELAY_MS=

DISCORD_WEBHOOK_URL=

# Backblaze B2 Storage
B2_KEY_ID=
B2_APP_KEY=
B2_DOWNLOAD_URL=                    # optional; auto-detected from authorize() response if blank

B2_BUCKET_INVOICES_ID=
B2_BUCKET_INVOICES_NAME=
B2_BUCKET_CLIENT_REQUESTS_ID=
B2_BUCKET_CLIENT_REQUESTS_NAME=
B2_BUCKET_DB_DUMPS_ID=
B2_BUCKET_DB_DUMPS_NAME=

#pg
PG_DUMP_BIN=/opt/homebrew/opt/postgresql@16/bin/pg_dump
# or on ubuntu
PG_DUMP_BIN=/usr/lib/postgresql/16/bin/pg_dump
