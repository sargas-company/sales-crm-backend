generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  passwordHash       String
  refreshTokenHash   String?
  createdAt          DateTime   @default(now())

  proposals Proposal[]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MessageRole {
  user
  assistant
}

// ─── Proposal / Chat ─────────────────────────────────────────────────────────

model Proposal {
  id        String   @id @default(uuid())
  title     String
  vacancy   String?
  comment   String?
  context   String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@index([createdAt])
  @@index([userId])
}

model ChatMessage {
  id         String      @id @default(uuid())
  proposalId String
  role       MessageRole
  content    String
  decision   String?
  reasoning  String?
  createdAt  DateTime    @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
}

model BaseKnowledge {
  id          String                 @id @default(uuid())
  title       String
  description String
  category    String
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([category])
  @@index([createdAt])
}

model Settings {
  id String @id @default("global")
  systemPrompt String
}
