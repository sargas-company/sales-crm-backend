generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String
  refreshTokenHash String?
  firstName        String
  lastName         String
  role             UserRole   @default(MANAGER)
  createdAt        DateTime   @default(now())

  proposals    Proposal[]
  accounts     Account[]
  clientCalls  ClientCall[]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
}

enum MessageRole {
  user
  assistant
}

enum ProposalStatus {
  Draft
  Sent
  Viewed
  Replied
}

enum ProposalType {
  Bid
  Invite
  DirectMessage
}

enum ProposalSource {
  telegram
  manual
}

enum JobPostStatus {
  NEW
  PROCESSING
  PROCESSED
  FAILED
}

enum JobPostDecision {
  approve
  maybe
  decline
}

enum JobPostPriority {
  high
  medium
  low
}

enum PromptType {
  JOB_GATEKEEPER
  JOB_EVALUATION
  CHAT_SYSTEM
  CHAT_FALLBACK
}

// ─── Platform ────────────────────────────────────────────────────────────────

model Platform {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  proposals Proposal[]
}

// ─── Account ─────────────────────────────────────────────────────────────────

model Account {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  platformId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  platform  Platform   @relation(fields: [platformId], references: [id])
  proposals Proposal[]

  @@index([userId])
}

enum LeadStatus {
  conversation_ongoing
  trial
  hold
  contract_offer
  accept_contract
  start_contract
  suspended
}

enum ClientType {
  individual
  company
}

// ─── Proposal / Chat ─────────────────────────────────────────────────────────

model Proposal {
  id              String         @id @default(uuid())
  title           String
  jobUrl          String?
  status          ProposalStatus @default(Draft)
  platformId      String?
  proposalType    ProposalType
  boosted         Boolean        @default(false)
  connects        Int            @default(0)
  boostedConnects Int            @default(0)
  sentAt          DateTime?
  coverLetter     String?
  vacancy         String?
  accountId       String?
  userId          String
  source          ProposalSource @default(manual)
  jobPostId       String?          @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  account  Account?  @relation(fields: [accountId], references: [id])
  platform Platform? @relation(fields: [platformId], references: [id])
  chat     Chat?
  lead     Lead?
  jobPost  JobPost?  @relation(fields: [jobPostId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([status])
}

// ─── JobPost (Telegram staging) ──────────────────────────────────────────────

model JobPost {
  id               String           @id @default(uuid())
  chatId           String
  messageId        Int
  rawText          String
  rawPayload       Json
  status           JobPostStatus    @default(NEW)
  decision         JobPostDecision?
  matchScore       Int?
  priority         JobPostPriority?
  aiResponse       Json?
  createdAt        DateTime         @default(now())
  processedAt      DateTime?

  // parsed fields
  title            String?
  jobUrl           String?
  scanner          String?
  gigRadarScore    Int?
  location         String?
  budget           String?
  totalSpent       Float?
  avgRatePaid      Float?
  hireRate         Float?
  hSkillsKeywords  String[]

  proposal Proposal?

  @@unique([chatId, messageId])
  @@index([status])
  @@index([decision])
}

model Chat {
  id         String   @id @default(uuid())
  proposalId String?  @unique
  leadId     String?  @unique
  createdAt  DateTime @default(now())

  proposal Proposal? @relation(fields: [proposalId], references: [id])
  lead     Lead?     @relation(fields: [leadId], references: [id])
  messages ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  chatId    String
  role      MessageRole
  content   String
  decision  String?
  reasoning String?
  createdAt DateTime    @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model BaseKnowledge {
  id          String                     @id @default(uuid())
  title       String
  description String
  category    String
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@index([category])
  @@index([createdAt])
}

// ─── Lead ────────────────────────────────────────────────────────────────────

model Lead {
  id         String     @id @default(uuid())
  number     Int        @unique @default(autoincrement())
  proposalId  String?    @unique
  firstName   String?
  lastName    String?
  companyName String?
  status      LeadStatus @default(conversation_ongoing)
  clientType  ClientType?
  rate       Int?
  location   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  repliedAt  DateTime   @default(now())
  acceptedAt DateTime?
  holdAt     DateTime?

  proposal    Proposal?    @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  chat        Chat?
  clientCalls ClientCall[]

  @@index([status])
  @@index([createdAt])
}

model Prompt {
  id        String     @id @default(uuid())
  type      PromptType
  title     String
  content   String
  isActive  Boolean    @default(false)
  version   Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  createdBy String?
  updatedBy String?

  @@index([type])
}

// ─── Counterparty ────────────────────────────────────────────────────────────

enum CounterpartyType {
  client
  contractor
}

model Counterparty {
  id        String          @id @default(uuid())
  firstName String
  lastName  String
  type      CounterpartyType
  info      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  invoices Invoice[]

  @@index([type])
}

// ─── Invoice ──────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  draft
  open
  paid
}

model Invoice {
  id               String        @id @default(uuid())
  counterpartyId   String

  status InvoiceStatus @default(draft)

  // Header
  header   String  @default("INVOICE")
  logoUrl  String?
  number   String?
  currency String  @default("USD")

  // Dates & meta
  date         DateTime?
  dueDate      DateTime?
  paymentTerms String?
  poNumber     String?

  // Addresses & text content
  fromValue String?  // sender info
  toValue   String?  // bill to
  shipTo    String?
  notes     String?
  terms     String?

  // Financial
  tax        Decimal? @db.Decimal(10, 2)
  discounts  Decimal? @db.Decimal(10, 2)
  shipping   Decimal? @db.Decimal(10, 2)
  amountPaid Decimal? @db.Decimal(10, 2)

  // Field visibility toggles
  showTax       Boolean @default(false)
  showDiscounts Boolean @default(false)
  showShipping  Boolean @default(false)
  showShipTo    Boolean @default(false)

  // Generated PDF path (uploads/invoices/{id}.pdf), null until first generation
  pdfUrl String?

  // Customizable labels — overrides for API *_title / *_header fields
  // e.g. { "to_title": "Billing Address", "unit_cost_header": "Price" }
  labels Json @default("{}")

  // Extra custom fields array
  // e.g. [{ "name": "Project", "value": "Website Redesign" }]
  customFields Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  counterparty Counterparty    @relation(fields: [counterpartyId], references: [id])
  lineItems    InvoiceLineItem[]

  @@index([counterpartyId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  name        String?
  description String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitCost    Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder   Int      @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── Notifications ───────────────────────────────────────────────────────────

enum NotificationType {
  JOB_POST_MATCH
  CLIENT_REQUEST
  CALL_REMINDER
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationChannel {
  DISCORD
}

model NotificationEvent {
  id        String           @id @default(uuid())
  type      NotificationType
  payload   Json
  createdAt DateTime         @default(now())

  deliveries NotificationDelivery[]

  @@index([type, createdAt(sort: Desc)])
}

model NotificationDelivery {
  id        String                     @id @default(uuid())
  eventId   String
  channel   NotificationChannel
  status    NotificationDeliveryStatus @default(PENDING)
  failedAttempts Int                   @default(0)
  sentAt    DateTime?
  error     String?
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  event NotificationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, channel])
  @@index([status, createdAt(sort: Desc)])
  @@index([eventId])
  @@index([channel, status])
}

// ─── Client Requests ─────────────────────────────────────────────────────────

enum ClientRequestStatus {
  on_review
  conversation_ongoing
  archived
}

model ClientRequest {
  id           String              @id @default(uuid())
  name         String
  company      String?
  email        String
  phone        String?
  phoneCountry String?
  message      String?
  services     String[]
  status       ClientRequestStatus @default(on_review)
  files        Json                @default("[]")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  clientCalls ClientCall[]

  @@index([createdAt])
  @@index([status])
}

// ─── Client Calls ─────────────────────────────────────────────────────────────

enum ClientCallClientType {
  lead
  client_request
}

enum ClientCallStatus {
  scheduled
  cancelled
  completed
}

model ClientCall {
  id              String               @id @default(uuid())
  clientType      ClientCallClientType
  leadId          String?
  clientRequestId String?
  createdById     String

  callTitle       String
  meetingUrl      String?

  scheduledAt     DateTime
  clientTimezone  String
  duration        Int

  status          ClientCallStatus     @default(scheduled)

  notes           String?
  summary         String?
  transcriptUrl   String?
  aiSummary       String?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  lead          Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientRequest ClientRequest? @relation(fields: [clientRequestId], references: [id], onDelete: Cascade)
  createdBy     User           @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([status])
  @@index([scheduledAt(sort: Desc)])
  @@index([leadId])
  @@index([clientRequestId])
}
