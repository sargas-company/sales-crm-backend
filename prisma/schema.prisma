generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String
  refreshTokenHash String?
  firstName        String
  lastName         String
  createdAt        DateTime   @default(now())

  proposals Proposal[]
  accounts  Account[]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MessageRole {
  user
  assistant
}

enum ProposalStatus {
  Draft
  Sent
  Viewed
  Replied
}

enum ProposalType {
  Bid
  Invite
  DirectMessage
}

// ─── Platform ────────────────────────────────────────────────────────────────

model Platform {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  proposals Proposal[]
}

// ─── Account ─────────────────────────────────────────────────────────────────

model Account {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  platformId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  platform  Platform   @relation(fields: [platformId], references: [id])
  proposals Proposal[]

  @@unique([userId, platformId])
  @@index([userId])
}

enum LeadStatus {
  conversation_ongoing
  trial
  hold
  contract_offer
  accept_contract
  start_contract
  suspended
}

enum ClientType {
  individual
  company
}

// ─── Proposal / Chat ─────────────────────────────────────────────────────────

model Proposal {
  id              String         @id @default(uuid())
  title           String
  jobUrl          String?
  status          ProposalStatus @default(Draft)
  platformId      String?
  proposalType    ProposalType
  boosted         Boolean        @default(false)
  connects        Int            @default(0)
  boostedConnects Int            @default(0)
  sentAt          DateTime?
  coverLetter     String?
  vacancy         String?
  accountId       String?
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  account  Account?  @relation(fields: [accountId], references: [id])
  platform Platform? @relation(fields: [platformId], references: [id])
  messages ChatMessage[]
  lead     Lead?

  @@index([createdAt])
  @@index([userId])
  @@index([status])
}

model ChatMessage {
  id         String      @id @default(uuid())
  proposalId String
  role       MessageRole
  content    String
  decision   String?
  reasoning  String?
  createdAt  DateTime    @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
}

model BaseKnowledge {
  id          String                     @id @default(uuid())
  title       String
  description String
  category    String
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@index([category])
  @@index([createdAt])
}

// ─── Lead ────────────────────────────────────────────────────────────────────

model Lead {
  id         String     @id @default(uuid())
  number     Int        @unique @default(autoincrement())
  proposalId String?    @unique
  leadName   String?
  status     LeadStatus @default(conversation_ongoing)
  clientType ClientType?
  rate       Int?
  location   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  repliedAt  DateTime   @default(now())
  acceptedAt DateTime?
  holdAt     DateTime?

  proposal Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model Settings {
  id           String @id @default("global")
  systemPrompt String
}
