generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  passwordHash       String
  refreshTokenHash   String?
  firstName          String
  lastName           String
  createdAt          DateTime   @default(now())

  proposals Proposal[]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MessageRole {
  user
  assistant
}

enum ProposalStatus {
  Draft
  Sent
  Viewed
  Replied
}

enum ProposalType {
  Bid
  Invite
  DirectMessage
}

enum Platform {
  Upwork
  LinkedIn
}

// ─── Proposal / Chat ─────────────────────────────────────────────────────────

model Proposal {
  id           String         @id @default(uuid())
  title        String
  jobUrl       String?
  status       ProposalStatus @default(Draft)
  account      String
  platform     Platform       @default(Upwork)
  proposalType ProposalType
  boosted         Boolean        @default(false)
  connects        Int            @default(0)
  boostedConnects Int            @default(0)
  sentAt       DateTime?
  coverLetter  String?
  vacancy      String?
  userId       String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@index([createdAt])
  @@index([userId])
  @@index([status])
}

model ChatMessage {
  id         String      @id @default(uuid())
  proposalId String
  role       MessageRole
  content    String
  decision   String?
  reasoning  String?
  createdAt  DateTime    @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
}

model BaseKnowledge {
  id          String                 @id @default(uuid())
  title       String
  description String
  category    String
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([category])
  @@index([createdAt])
}

model Settings {
  id String @id @default("global")
  systemPrompt String
}
